# API 호출 모드
# - mock   : 로컬 개발 (Express 목서버 사용, pnpm dev:mock)
# - static : 데모 배포 (정적 JSON/준비중 응답, 부분적으로 실서버)
# - real   : 프로덕션 (전부 실서버)
NEXT_PUBLIC_API_MODE=mock

# API base URL
# - mock 모드  : Express 목서버 주소 (http://localhost:9090)
# - static/real 모드: 실서버 도메인
NEXT_PUBLIC_API_BASE_URL=http://localhost:9090
